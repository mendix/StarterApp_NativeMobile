                </property>
                <property key="clear_label" type="textTemplate" required="false">
                    <caption>Clear</caption>
                    <description>These button labels are only used by the Feedback Button, Take Screenshot and Annotation tool.
                    &#xA;If you would like to edit the button labels for the Feedback modal pop-up, please navigate to Feedback Module &#62; USE_ME &#62; Pages.</description>
                    <translations>
                        <translation lang="en_US">Clear</translation>
                        <translation lang="en_GB">Clear</translation>
                        <translation lang="nl_NL">Aantekening verwijderen</translation>
                        <translation lang="fr_FR">Nettoyer</translation>
                        <translation lang="de_DE">Sauber machen</translation>
                        <translation lang="pt_PT">Limpar</translation>
