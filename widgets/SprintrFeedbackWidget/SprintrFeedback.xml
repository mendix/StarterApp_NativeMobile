                        <translation lang="es_ES">Dar feedback sobre el sitio web</translation>
                        <translation lang="tr_TR">Web sitesi geri bildirimi ver</translation>
                        <translation lang="it_IT">Dai feedback sul sito web</translation>
                    </translations>
                </property>
                <property key="take_screenshot_label" type="textTemplate" required="false">
                    <caption>Take screenshot</caption>
                    <description />
                    <translations>
                        <translation lang="en_US">Take screenshot</translation>
                        <translation lang="en_GB">Take screenshot</translation>
                        <translation lang="nl_NL">Schermopname maken</translation>
