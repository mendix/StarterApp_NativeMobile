<?xml version="1.0" encoding="utf-8" ?>
<widget
    id="SprintrFeedbackWidget.SprintrFeedback"
    pluginWidget="true"
    needsEntityContext="false"
    offlineCapable="false"
    supportedPlatform="Web"
    xmlns="http://www.mendix.com/widget/1.0/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>Feedback</name>
    <description>Mendix Feedback Widget</description>
    <studioProCategory>Feedback</studioProCategory>
    <studioCategory>Feedback</studioCategory>
    <helpUrl>https://docs.mendix.com/appstore/widgets/mendix-feedback/</helpUrl>
    <icon>
        
    </icon>
    <properties>
        <!-- PROJECT CONFIGURATION -->
        <propertyGroup caption="Configuration">
            <propertyGroup caption="Feedback button action">
                <property key="feedbackButtonAction" type="action" defaultType="CallNanoflow" defaultValue="FeedbackModule.ACT_Open_Feedback_Modal">
                    <caption>On click action</caption>
                    <description>The default on-click action is the 'ACT_Open_Feedback_Modal' nanoflow, which opens the Feedback Modal pop-up.</description>
                </property>
            </propertyGroup>
            <propertyGroup caption="Project settings">
                <property key="sprintrapp" type="string" required="true" defaultValue="1">
                    <caption>App ID</caption>
                    <description>The App ID is added automatically by Studio Pro. You can find it in the Developer Portal under Your App > Settings > General. By overwriting the App ID you can send Feedback to another app.</description>
                </property>
            </propertyGroup>
            <propertyGroup caption="Advanced settings">
                <property key="showAdvancedSettings" type="boolean" defaultValue="false">
                    <caption>Show advanced settings</caption>
                    <description>These options allow you to customize where the widget renders and how screenshots are captured when default behavior doesn't work as expected.&#xA;</description>
                </property>
                <property key="targetContainerSelector" type="string" required="true" defaultValue=".mx-scrollcontainer-center">
                    <caption>Target container selector</caption>
                    <description>CSS selector for the container where the feedback widget should be rendered. Defaults to '.mx-scrollcontainer-center'.</description>
                </property>
                <property key="foreignObjectRendering" type="boolean" defaultValue="false">
                    <caption>Enable object rendering</caption>
                    <description>Only enable this when you experience problems with creating screenshots.
                    &#xA;This will enable the 'foreignObjectRendering' method which helps rendering complex HTML, including styles, SVGs, and embedded elements.&#xA;</description>
                </property>
                <property
                    key="scrollableAreaSelector"
                    type="string"
                    required="false"
                    defaultValue=".mx-scrollcontainer-fixed > .mx-scrollcontainer-middle > .mx-scrollcontainer-wrapper">
                    <caption>CSS scrollable area</caption>
                    <description>If your app doesn't use the default scrolling behavior in Studio Pro, the screenshot feature might not work correctly. Add a CSS selector to specify which element on your page scrolls the content.</description>
                </property>
            </propertyGroup>   
            <propertyGroup caption="Visibility">
                <systemProperty key="Visibility" />
            </propertyGroup>   
        </propertyGroup>
        <!-- Translation -->
        <propertyGroup caption="Customize button">
            <propertyGroup caption="Feedback and screenshot button labels">
                <property key="title_label" type="textTemplate" required="false">
                    <caption>Feedback</caption>
                    <description />
                    <translations>
                        <translation lang="en_US">Feedback</translation>
                        <translation lang="en_GB">Feedback</translation>
                        <translation lang="nl_NL">Feedback</translation>
                        <translation lang="fr_FR">Feedback</translation>
                        <translation lang="de_DE">Feedback</translation>
                        <translation lang="pt_PT">Feedback</translation>
                        <translation lang="hi_IN">प्रतिक्रिया</translation>
                        <translation lang="es_ES">Comentarios</translation>
                        <translation lang="tr_TR">Geri Bildirim</translation>
                        <translation lang="it_IT">Feedback</translation>
                    </translations>
                </property>
                <property key="feedbackStartButtonAriaLabel" type="textTemplate" required="false">
                    <caption>Give website feedback</caption>
                    <description>Web accessible aria label for the feedback start button.</description>
                    <translations>
                        <translation lang="en_US">Give website feedback</translation>
