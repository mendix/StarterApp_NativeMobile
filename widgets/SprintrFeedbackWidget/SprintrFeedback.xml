                    </translations>
                </property>
            </propertyGroup>
                <propertyGroup caption="Feedback button styling">
                <property key="userDefinedButtonStyle" type="enumeration" defaultValue="side">
                    <caption>Render mode</caption>
                    <description>Choose how the feedback button renders on your apps page.&#xA;If set to 'Do not render', the Feedback Button will not show to users visiting your app.</description>
                    <enumerationValues>
                        <enumerationValue key="side">Side tab</enumerationValue>
                        <enumerationValue key="normal">Button</enumerationValue>
                        <enumerationValue key="none">Do not render</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="showInDesignMode" type="boolean" defaultValue="true">
                    <caption>Show in Design mode</caption>
                    <description>In Mendix Studio Pro you can show or hide the Feedback widget button from the page editor when using Design mode.</description>
                </property>
            </propertyGroup>
        </propertyGroup>
    </properties>
</widget>
